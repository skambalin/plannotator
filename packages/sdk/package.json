{
  "name": "@plannotator/sdk",
  "version": "0.16.2",
  "private": false,
  "type": "module",
  "description": "Plannotator SDK — server-side capabilities for external plugin projects",
  "author": "backnotprop",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/backnotprop/plannotator.git",
    "directory": "packages/sdk"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "typecheck": "bunx tsc --noEmit"
  },
  "peerDependencies": {
    "bun": ">= 1.0.0"
  },
  "devDependencies": {
    "@plannotator/ai": "workspace:*",
    "@plannotator/server": "workspace:*",
    "@plannotator/shared": "workspace:*",
    "dts-bundle-generator": "^9.5.1"
  }
}
